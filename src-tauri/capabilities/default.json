{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for BookmarkShelf",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    "fs:allow-home-meta-recursive",
    "shell:allow-open"
  ]
}
